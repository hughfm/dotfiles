# target: ~/.aliases

alias zshconfig="vim ~/.zshrc"
alias ohmyzsh="vim ~/.oh-my-zsh"

alias gbdf='git branch -d $(git branch | FZF)'
alias 'gbdf!'='git branch -D $(git branch | FZF)'
alias grb='git checkout $(git branch --sort=-committerdate | FZF)'
alias gsn='git status -uno'

if command -v nvim > /dev/null; then
  nvim() {
    local root socket
    root=$(git rev-parse --show-toplevel 2>/dev/null || realpath "$PWD")
    socket="/tmp/nvim-$(printf '%s' "$root" | md5sum | cut -c1-8)"
    command nvim --listen "$socket" "$@"
  }
  alias v=nvim
  alias vi=nvim
  alias vim=nvim
fi

if command -v bat > /dev/null; then
  alias cat='bat'
  alias ag='ag --pager bat'
fi
